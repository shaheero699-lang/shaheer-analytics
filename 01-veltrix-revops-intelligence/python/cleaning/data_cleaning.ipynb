# Cell 1 - Markdown
"""
# Data Cleaning Pipeline
## Veltrix AI RevOps Intelligence Platform
Cleans and validates all 6 raw datasets for downstream analysis.
"""

# Cell 2
import pandas as pd
import numpy as np

# Load datasets
customers = pd.read_csv('../data/raw/customers.csv')
subscriptions = pd.read_csv('../data/raw/subscriptions.csv')
support_tickets = pd.read_csv('../data/raw/support_tickets.csv')

print("Datasets loaded successfully")
print(f"Customers: {customers.shape}")
print(f"Subscriptions: {subscriptions.shape}")
print(f"Support Tickets: {support_tickets.shape}")

# Cell 3 - Check missing values
print("\n=== Missing Values ===")
for df, name in [(customers, 'customers'), 
                 (subscriptions, 'subscriptions'),
                 (support_tickets, 'support_tickets')]:
    missing = df.isnull().sum()
    if missing.any():
        print(f"\n{name}:")
        print(missing[missing > 0])

# Cell 4 - Clean customers
customers['company_name'] = customers['company_name'].str.strip()
customers['plan_type'] = customers['plan_type'].str.lower()
customers['region'] = customers['region'].str.upper()
customers['onboarding_days'] = customers['onboarding_days'].fillna(0)
customers['industry'] = customers['industry'].fillna('Unknown')

# Cell 5 - Add health segment
customers['health_segment'] = pd.cut(
    customers['customer_health_score'],
    bins=[0, 50, 75, 100],
    labels=['At Risk', 'Moderate', 'Healthy']
)

# Cell 6 - Remove duplicates
print(f"\nDuplicates removed: {customers.duplicated().sum()}")
customers = customers.drop_duplicates()

# Cell 7 - Save cleaned data
customers.to_csv('../data/processed/customers_cleaned.csv', index=False)
print("\nCleaned data saved to /data/processed/")
